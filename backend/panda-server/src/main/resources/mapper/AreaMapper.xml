<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.panda.mapper.AreaMapper">

    <select id="getById" resultType="com.panda.entity.Area">
        select id, name, polygon, create_time
        from area
        where id = #{id}
    </select>

    <select id="listAll" resultType="com.panda.entity.Area">
        select id, name, polygon, create_time
        from area
        order by id desc
    </select>

</mapper>
