<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.panda.mapper.FaultReportMapper">

    <resultMap id="faultReportResultMap" type="com.panda.entity.FaultReport">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="scooterId" column="scooter_id"/>
        <result property="description" column="description"/>
        <result property="imageUrl" column="image_url"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.panda.entity.FaultReport" useGeneratedKeys="true" keyProperty="id">
        insert into fault_report (user_id, scooter_id, description, image_url, status, create_time)
        values (#{userId}, #{scooterId}, #{description}, #{imageUrl}, #{status}, #{createTime})
    </insert>

    <select id="listByUserId" resultMap="faultReportResultMap">
        select id, user_id, scooter_id, description, image_url, status, create_time
        from fault_report
        where user_id = #{userId}
        order by id desc
    </select>

</mapper>
