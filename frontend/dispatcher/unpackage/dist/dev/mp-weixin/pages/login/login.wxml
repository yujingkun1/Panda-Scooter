<view class="page"><view class="hero"><image class="logo" src="{{a}}" mode="aspectFit"></image><text class="title">{{b}}</text><text class="subtitle">{{c}}</text></view><view class="card"><view class="tabs"><view wx:for="{{d}}" wx:for-item="item" wx:key="b" class="{{['tab', item.c && 'active']}}" bindtap="{{item.d}}"><text class="tab-text">{{item.a}}</text></view></view><view wx:if="{{e}}" class="field"><text class="label">Name</text><input class="input" type="text" placeholder="Enter real name" value="{{f}}" bindinput="{{g}}"/></view><view class="field"><text class="label">Email</text><input class="input" type="text" placeholder="Enter email" value="{{h}}" bindinput="{{i}}"/></view><view wx:if="{{j}}" class="field"><text class="label">Password</text><input class="input" password type="text" placeholder="Enter password" value="{{k}}" bindinput="{{l}}"/></view><view wx:if="{{m}}" class="field"><text class="label">New Password</text><input class="input" password type="text" placeholder="Enter new password" value="{{n}}" bindinput="{{o}}"/></view><view wx:if="{{p}}" class="field"><text class="label">Verification Code</text><view class="inline-field"><input class="input inline-input" type="text" placeholder="Enter code" value="{{q}}" bindinput="{{r}}"/><button class="code-btn" disabled="{{t}}" bindtap="{{v}}">{{s}}</button></view></view><button class="submit-btn" bindtap="{{x}}">{{w}}</button><view class="footer-links"><text wx:if="{{y}}" class="link" bindtap="{{z}}">Create Account</text><text wx:if="{{A}}" class="divider">|</text><text wx:if="{{B}}" class="link" bindtap="{{C}}">Reset Password</text><text wx:if="{{D}}" class="link" bindtap="{{E}}">Back to Login</text></view></view></view>