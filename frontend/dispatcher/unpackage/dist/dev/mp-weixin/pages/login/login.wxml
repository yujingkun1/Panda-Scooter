<view class="page"><view class="hero"><image class="logo" src="{{a}}" mode="aspectFit"></image><text class="title">{{b}}</text><text class="subtitle">{{c}}</text></view><view class="card"><view class="tabs"><view wx:for="{{d}}" wx:for-item="item" wx:key="b" class="{{['tab', item.c && 'active']}}" bindtap="{{item.d}}"><text class="tab-text">{{item.a}}</text></view></view><view wx:if="{{e}}" class="field"><text class="label">姓名</text><input class="input" type="text" placeholder="请输入真实姓名" value="{{f}}" bindinput="{{g}}"/></view><view class="field"><text class="label">邮箱</text><input class="input" type="text" placeholder="请输入邮箱" value="{{h}}" bindinput="{{i}}"/></view><view wx:if="{{j}}" class="field"><text class="label">密码</text><input class="input" password type="text" placeholder="请输入密码" value="{{k}}" bindinput="{{l}}"/></view><view wx:if="{{m}}" class="field"><text class="label">新密码</text><input class="input" password type="text" placeholder="请输入新密码" value="{{n}}" bindinput="{{o}}"/></view><view wx:if="{{p}}" class="field"><text class="label">验证码</text><view class="inline-field"><input class="input inline-input" type="text" placeholder="请输入验证码" value="{{q}}" bindinput="{{r}}"/><button class="code-btn" disabled="{{t}}" bindtap="{{v}}">{{s}}</button></view></view><button class="submit-btn" bindtap="{{x}}">{{w}}</button><view class="footer-links"><text wx:if="{{y}}" class="link" bindtap="{{z}}">去注册</text><text wx:if="{{A}}" class="divider">|</text><text wx:if="{{B}}" class="link" bindtap="{{C}}">忘记密码</text><text wx:if="{{D}}" class="link" bindtap="{{E}}">返回登录</text></view></view></view>