<view class="page"><view class="hero"><image class="logo" src="{{a}}" mode="aspectFit"></image><text class="title">{{b}}</text><text class="subtitle">{{c}}</text></view><view class="card"><view class="tabs"><view wx:for="{{d}}" wx:for-item="item" wx:key="b" class="{{['tab', 'ui-pressable', item.c && 'active']}}" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{item.d}}"><text class="tab-text">{{item.a}}</text></view></view><view wx:if="{{e}}" class="field"><text class="label">姓名</text><input class="input" type="text" placeholder="请输入真实姓名" value="{{f}}" bindinput="{{g}}"/></view><view class="field"><text class="label">邮箱</text><input class="input" type="text" placeholder="请输入邮箱" value="{{h}}" bindinput="{{i}}"/></view><view class="field"><text class="label">密码</text><input class="input" password type="text" placeholder="请输入密码" value="{{j}}" bindinput="{{k}}"/></view><view wx:if="{{l}}" class="field"><text class="label">验证码</text><view class="inline-field"><input class="input inline-input" type="text" placeholder="请输入验证码" value="{{m}}" bindinput="{{n}}"/><button class="code-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" disabled="{{p}}" bindtap="{{q}}">{{o}}</button></view></view><button class="submit-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" bindtap="{{s}}">{{r}}</button><view class="footer-links"><view wx:if="{{t}}" class="link-button ui-pressable-inline" hover-class="ui-pressable-inline-hover" hover-stay-time="70" bindtap="{{v}}"><text class="link">去注册</text></view><view wx:if="{{w}}" class="link-button ui-pressable-inline" hover-class="ui-pressable-inline-hover" hover-stay-time="70" bindtap="{{x}}"><text class="link">返回登录</text></view></view></view></view>