<view class="page"><view class="hero"><image class="logo" src="{{a}}" mode="aspectFit"></image><text class="title">{{b}}</text><text class="subtitle">{{c}}</text></view><view class="card"><view class="tabs"><view wx:for="{{d}}" wx:for-item="item" wx:key="b" class="{{['tab', 'ui-pressable', item.c && 'active']}}" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{item.d}}"><text class="tab-text">{{item.a}}</text></view></view><view wx:if="{{e}}" class="field"><text class="label">Name</text><input class="input" type="text" placeholder="Enter your real name" value="{{f}}" bindinput="{{g}}"/></view><view class="field"><text class="label">Email</text><input class="input" type="text" placeholder="Enter your email" value="{{h}}" bindinput="{{i}}"/></view><view class="field"><text class="label">Password</text><input class="input" password type="text" placeholder="Enter your password" value="{{j}}" bindinput="{{k}}"/></view><view wx:if="{{l}}" class="field"><text class="label">Verification Code</text><view class="inline-field"><input class="input inline-input" type="text" placeholder="Enter the code" value="{{m}}" bindinput="{{n}}"/><button class="code-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" disabled="{{p}}" bindtap="{{q}}">{{o}}</button></view></view><button class="submit-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" disabled="{{s}}" bindtap="{{t}}">{{r}}</button><view class="footer-links"><view wx:if="{{v}}" class="link-button ui-pressable-inline" hover-class="ui-pressable-inline-hover" hover-stay-time="70" bindtap="{{w}}"><text class="link">Create Account</text></view><view wx:if="{{x}}" class="link-button ui-pressable-inline" hover-class="ui-pressable-inline-hover" hover-stay-time="70" bindtap="{{y}}"><text class="link">Forgot Password</text></view><view wx:if="{{z}}" class="link-button ui-pressable-inline" hover-class="ui-pressable-inline-hover" hover-stay-time="70" bindtap="{{A}}"><text class="link">Back To Login</text></view></view></view></view>