<view class="page"><view class="header"><text class="title">账号管理</text></view><view class="info-section"><view class="info-item"><text class="info-label">姓名</text><text class="info-value">{{a}}</text></view><view class="info-item"><text class="info-label">邮箱</text><text class="info-value">{{b}}</text></view></view><view class="action-section"><view class="action-item" bindtap="{{c}}"><text class="action-text">修改密码</text><text class="action-arrow">&gt;</text></view><view class="action-item" bindtap="{{d}}"><text class="action-text logout-text">退出登录</text></view></view><view class="delete-section"><text class="section-title">注销账号</text><text class="section-desc">注销前需要输入当前登录密码与邮箱验证码。</text><view class="field"><text class="field-label">登录密码</text><input class="input" password type="text" placeholder="请输入当前密码" value="{{e}}" bindinput="{{f}}"/></view><view class="field"><text class="field-label">邮箱验证码</text><view class="code-row"><input class="input code-input" type="text" placeholder="请输入验证码" value="{{g}}" bindinput="{{h}}"/><button class="code-btn" disabled="{{j}}" bindtap="{{k}}">{{i}}</button></view></view><button class="delete-btn" bindtap="{{l}}">确认注销</button></view></view>