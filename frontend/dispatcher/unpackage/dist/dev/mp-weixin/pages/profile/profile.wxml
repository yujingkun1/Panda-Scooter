<view class="page"><view class="header"><image class="avatar" src="{{a}}" mode="aspectFit"></image><view class="user-info"><text class="username">{{b}}</text><text class="email">{{c}}</text></view><view class="account-manage" bindtap="{{d}}"><text class="manage-text">Account</text></view></view><view class="stats-section"><view class="stat-item"><text class="stat-value">{{e}}</text><text class="stat-label">Assigned Area</text></view><view class="stat-divider"></view><view class="stat-item"><text class="stat-value">{{f}}</text><text class="stat-label">Today Count</text></view></view><view wx:if="{{g}}" class="guest-card"><text class="guest-title">Guest mode is active</text><text class="guest-desc">Sign in to access dispatch actions, history and account details.</text><button class="login-btn" bindtap="{{h}}">Sign In</button></view><view class="menu-section"><view class="menu-item" bindtap="{{i}}"><text class="menu-text">Dispatch Unlock</text><text class="menu-arrow">&gt;</text></view><view class="menu-item" bindtap="{{j}}"><text class="menu-text">Lock Placement</text><text class="menu-arrow">&gt;</text></view><view class="menu-item" bindtap="{{k}}"><text class="menu-text">Dispatch History</text><text class="menu-arrow">&gt;</text></view></view></view>