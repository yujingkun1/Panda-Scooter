<view class="page"><view class="header"><image class="avatar" src="{{a}}" mode="aspectFit"></image><view class="user-info"><text class="username">{{b}}</text><text class="email">{{c}}</text></view><view class="account-manage" bindtap="{{d}}"><text class="manage-text">账号管理</text></view></view><view class="stats-section"><view class="stat-item"><text class="stat-value">{{e}}</text><text class="stat-label">负责辖区</text></view><view class="stat-divider"></view><view class="stat-item"><text class="stat-value">{{f}}</text><text class="stat-label">今日调度数量</text></view></view><view wx:if="{{g}}" class="guest-card"><text class="guest-title">当前为访客模式</text><text class="guest-desc">登录后可查看收入、调度任务和调度历史。</text><button class="login-btn" bindtap="{{h}}">去登录</button></view><view class="menu-section"><view class="menu-item" bindtap="{{i}}"><text class="menu-text">我的收入</text></view><view class="menu-item" bindtap="{{j}}"><text class="menu-text">调度任务</text></view><view class="menu-item" bindtap="{{k}}"><text class="menu-text">调度历史</text></view></view></view>