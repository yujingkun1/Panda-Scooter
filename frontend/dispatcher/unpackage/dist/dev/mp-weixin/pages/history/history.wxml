<view class="page"><view class="header"><text class="title">Dispatch History</text></view><view wx:if="{{a}}" class="guest-card"><text class="guest-title">Sign in to view dispatch history.</text><button class="login-btn" bindtap="{{b}}">Sign In</button></view><block wx:else><view class="filter-section"><view class="{{['filter-item', c && 'active']}}" bindtap="{{d}}"><text class="filter-text">All</text></view><view class="{{['filter-item', e && 'active']}}" bindtap="{{f}}"><text class="filter-text">Unlock</text></view><view class="{{['filter-item', g && 'active']}}" bindtap="{{h}}"><text class="filter-text">Lock</text></view></view><view class="history-list"><view wx:if="{{i}}"><view wx:for="{{j}}" wx:for-item="item" wx:key="j" class="history-item"><view class="history-header"><view><text class="history-code">{{item.a}}</text><text class="history-time">{{item.b}}</text></view><view class="{{['history-tag', item.d]}}"><text class="tag-text">{{item.c}}</text></view></view><view class="history-body"><view class="info-row"><text class="info-label">Status</text><text class="info-value">{{item.e}}</text></view><view class="info-row"><text class="info-label">Battery</text><text class="info-value">{{item.f}}</text></view><view class="info-row"><text class="info-label">Position</text><text class="info-value">{{item.g}}</text></view><view wx:if="{{item.h}}" class="info-row"><text class="info-label">Remark</text><text class="info-value">{{item.i}}</text></view></view></view></view><view wx:else class="empty-history"><text class="empty-text">No dispatch record yet.</text></view></view></block></view>