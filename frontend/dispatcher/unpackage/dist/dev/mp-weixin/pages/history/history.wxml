<view class="page"><view class="header"><text class="title">调度历史</text></view><view class="filter-section"><view class="{{['filter-item', a && 'active']}}" bindtap="{{b}}"><text class="filter-text">全部</text></view><view class="{{['filter-item', c && 'active']}}" bindtap="{{d}}"><text class="filter-text">今日</text></view><view class="{{['filter-item', e && 'active']}}" bindtap="{{f}}"><text class="filter-text">调度中</text></view></view><view class="history-list"><view wx:if="{{g}}"><view wx:for="{{h}}" wx:for-item="item" wx:key="o" class="history-item"><view class="history-header"><view><text class="history-code">{{item.a}}</text><text class="history-time">开始时间 {{item.b}}</text></view><view class="{{['history-tag', item.d]}}"><text class="tag-text">{{item.c}}</text></view></view><view class="history-body"><view wx:if="{{item.e}}" class="info-row"><text class="info-label">结束时间</text><text class="info-value">{{item.f}}</text></view><view class="info-row"><text class="info-label">车辆状态</text><text class="info-value">{{item.g}}</text></view><view class="info-row"><text class="info-label">故障状态</text><text class="{{['info-value', item.i && 'fault-text']}}">{{item.h}}</text></view><view class="info-row"><text class="info-label">电量</text><text class="info-value">{{item.j}}</text></view></view><view wx:if="{{item.k}}" class="action-row"><button class="lock-btn" disabled="{{item.m}}" bindtap="{{item.n}}">{{item.l}}</button></view></view></view><view wx:else class="empty-history"><text class="empty-text">暂无调度记录。</text></view></view></view>