<view class="page"><view class="header"><text class="title">调度历史</text></view><view wx:if="{{a}}" class="guest-card"><text class="guest-title">登录后可查看调度历史记录。</text><button class="login-btn" bindtap="{{b}}">去登录</button></view><block wx:else><view class="filter-section"><view class="{{['filter-item', c && 'active']}}" bindtap="{{d}}"><text class="filter-text">全部</text></view><view class="{{['filter-item', e && 'active']}}" bindtap="{{f}}"><text class="filter-text">开锁调度</text></view><view class="{{['filter-item', g && 'active']}}" bindtap="{{h}}"><text class="filter-text">关锁投放</text></view></view><view class="history-list"><view wx:if="{{i}}"><view wx:for="{{j}}" wx:for-item="item" wx:key="j" class="history-item"><view class="history-header"><view><text class="history-code">{{item.a}}</text><text class="history-time">{{item.b}}</text></view><view class="{{['history-tag', item.d]}}"><text class="tag-text">{{item.c}}</text></view></view><view class="history-body"><view class="info-row"><text class="info-label">状态</text><text class="info-value">{{item.e}}</text></view><view class="info-row"><text class="info-label">电量</text><text class="info-value">{{item.f}}</text></view><view class="info-row"><text class="info-label">位置</text><text class="info-value">{{item.g}}</text></view><view wx:if="{{item.h}}" class="info-row"><text class="info-label">备注</text><text class="info-value">{{item.i}}</text></view></view></view></view><view wx:else class="empty-history"><text class="empty-text">暂无调度记录。</text></view></view></block></view>