<view class="page"><view class="header"><view class="brand"><image class="logo" src="{{a}}" mode="aspectFit"></image><view class="brand-text"><text class="brand-title">熊猫调度</text><text class="brand-subtitle">{{b}}</text></view></view><image class="avatar" src="{{c}}" mode="aspectFit" bindtap="{{d}}"></image></view><view class="map-container"><map class="map" latitude="{{e}}" longitude="{{f}}" scale="{{g}}" markers="{{h}}" polygons="{{i}}" show-location="{{true}}" bindmarkertap="{{j}}"></map></view><view wx:if="{{k}}" class="guest-card"><text class="guest-title">登录后可查看个人辖区并执行开锁调度、关锁投放等任务。</text><button class="login-btn" bindtap="{{l}}">去登录</button></view><block wx:else><view class="summary-card"><view class="summary-item"><text class="summary-label">调度员</text><text class="summary-value">{{m}}</text></view><view class="summary-divider"></view><view class="summary-item"><text class="summary-label">今日调度</text><text class="summary-value">{{n}}</text></view><view class="summary-divider"></view><view class="summary-item"><text class="summary-label">可用车辆</text><text class="summary-value">{{o}}</text></view></view><view class="function-area"><view class="function-item" bindtap="{{p}}"><text class="function-text">开锁调度</text></view><text class="function-divider">|</text><view class="function-item" bindtap="{{q}}"><text class="function-text">关锁投放</text></view><text class="function-divider">|</text><view class="function-item" bindtap="{{r}}"><text class="function-text">调度历史</text></view></view><view class="tip-card"><text class="tip-title">地图说明</text><text class="tip-desc">蓝色范围为调度辖区，红色透明区域为禁停区，图标用于标示车辆、停车点与禁停区中心。</text></view></block></view>