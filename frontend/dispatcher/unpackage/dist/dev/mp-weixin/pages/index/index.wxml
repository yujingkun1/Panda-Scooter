<view class="page"><view class="header"><view class="brand"><image class="logo" src="{{a}}" mode="aspectFit"></image><view class="brand-text"><text class="brand-title">Panda Dispatch</text><text class="brand-subtitle">{{b}}</text></view></view><image class="avatar" src="{{c}}" mode="aspectFit" bindtap="{{d}}"></image></view><view class="map-container"><map class="map" latitude="{{e}}" longitude="{{f}}" scale="{{g}}" markers="{{h}}" polygons="{{i}}" show-location="{{true}}" bindmarkertap="{{j}}"></map></view><view wx:if="{{k}}" class="guest-card"><text class="guest-title">Sign in to view your dispatch area and perform unlock or lock tasks.</text><button class="login-btn" bindtap="{{l}}">Sign In</button></view><block wx:else><view class="summary-card"><view class="summary-item"><text class="summary-label">Dispatcher</text><text class="summary-value">{{m}}</text></view><view class="summary-divider"></view><view class="summary-item"><text class="summary-label">Today</text><text class="summary-value">{{n}}</text></view><view class="summary-divider"></view><view class="summary-item"><text class="summary-label">Scooters</text><text class="summary-value">{{o}}</text></view></view><view class="function-area"><view class="function-item" bindtap="{{p}}"><text class="function-text">Dispatch Unlock</text></view><text class="function-divider">|</text><view class="function-item" bindtap="{{q}}"><text class="function-text">Lock Placement</text></view><text class="function-divider">|</text><view class="function-item" bindtap="{{r}}"><text class="function-text">History</text></view></view><view class="tip-card"><text class="tip-title">Map Guide</text><text class="tip-desc">Blue polygon is the dispatch area. Red transparent polygons are no-parking zones. Markers show scooters, parking points and no-parking centers.</text></view></block></view>