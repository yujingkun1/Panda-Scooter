<view class="page"><view class="header"><view class="brand"><image class="logo" src="{{a}}" mode="aspectFit"></image><view class="brand-text"><text class="brand-title">熊猫调度</text><text class="brand-subtitle">{{b}}</text></view></view><view class="avatar-hit ui-pressable" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{d}}"><image class="avatar" src="{{c}}" mode="aspectFit"></image></view></view><view class="map-container"><map class="map" latitude="{{e}}" longitude="{{f}}" scale="{{g}}" markers="{{h}}" polygons="{{i}}" show-location="{{true}}" bindmarkertap="{{j}}"></map></view><view class="unlock-section"><button class="unlock-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" disabled="{{l}}" bindtap="{{m}}"><text class="unlock-btn-text">{{k}}</text></button></view><view class="function-area"><view class="function-item ui-pressable" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{n}}"><text class="function-text">车辆查询</text></view><text class="function-divider">|</text><view class="function-item ui-pressable" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{o}}"><text class="function-text">编号开锁</text></view><text class="function-divider">|</text><view class="function-item ui-pressable" hover-class="ui-pressable-hover" hover-stay-time="70" bindtap="{{p}}"><text class="function-text">调度历史</text></view></view><view class="panel-area"><view wx:if="{{q}}" class="guest-card"><text class="guest-title">登录后可执行扫码开锁、编号开锁和查看调度记录。</text><button class="login-btn" hover-class="button-hover" hover-start-time="0" hover-stay-time="90" bindtap="{{r}}">去登录</button></view><view wx:else class="stats-card"><view class="stats-item"><text class="stats-label">辖区名称</text><text class="stats-value">{{s}}</text></view><view class="stats-divider"></view><view class="stats-item"><text class="stats-label">今日调度数量</text><text class="stats-value">{{t}}</text></view></view></view></view>